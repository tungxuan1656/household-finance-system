# Copy this file to .dev.vars for local worker runtime.
# Do not commit .dev.vars.

# Core auth settings
AUTH_ISSUER="https://fos.local"
AUTH_AUDIENCE="fos-api"
ACCESS_TOKEN_TTL_SECONDS="86400"
REFRESH_TOKEN_TTL_SECONDS="2592000"

# Firebase identity provider settings
FIREBASE_PROJECT_ID="fos-local"
FIREBASE_JWKS_URL="https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com"
AUTH_ALLOW_INSECURE_TEST_TOKENS="false"

# Secrets
AUTH_JWT_SECRET="replace-with-local-secret"
AUTH_REFRESH_TOKEN_PEPPER="replace-with-local-pepper"
