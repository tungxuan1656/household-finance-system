{
  "name": "tma",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit --project tsconfig.json && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@tma.js/sdk": "^3.2.0",
